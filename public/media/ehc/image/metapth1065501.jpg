<!DOCTYPE html>
<html lang="en">
<head>
    <meta http-equiv="Content-Type" content="text/html;  charset=UTF-8" />
    <meta name="robots" content="noindex,nofollow">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DAM</title>
    <link rel="stylesheet" href="/pth/media/dam/dam.css">
    <script async defer src="/pth/media/altcha/altcha.min.js" type="module"></script>
</head>
<body>
    <div id="altcha-content">
        <h1><img src="/pth/media/assets/public/images/pth/favicons/favicon.ico"> texashistory.unt.edu</h1>
        <h2>Gauging your humanity...This may take some seconds.</h2>
        <div>
            <form id="altcha-submission">
                <input type="hidden" name="csrfmiddlewaretoken" value="LsGRYe3xETMa9wuZ9cMLd7ZhBKVoBjaVMI2DqwxraNsU4xF1eQEp8CansTyL6RSB">
                <altcha-widget id="altcha"></altcha-widget>
            </form>
        </div>
        
            <h3>If you are unable to reach our site content, please <a href="https://texashistory.unt.edu/feedback/?cat=Technical+Issue&user_feedback=Altcha+Challenge+Issue+Details%3A">let us know</a>.</h3>
        
    </div>
    <script type="text/javascript">
        window.addEventListener("load", () => {
            document.querySelector("#altcha").configure({
                challenge: {
                    algorithm: "SHA-256",
                    challenge: "d4d3debfef06fd4ad8ac5eb259fb614949f69a371b83c43b6ff475b2c196ca5d",
                    salt: "1aa2ffa1fd78525d9bbed988?expires=1778098706",
                    signature: "339f5a7fb3da8f6910ba36377e60b4c81a97c44caf4bdd6278958fd03f1f9000",
                    maxnumber: "500000",
                },
                auto: "onload",
                debug: false,
                delay: 0,
                hidefooter: true,
                hidelogo: false,
            });
        });
        document.querySelector("altcha-widget").addEventListener("statechange", async (e) => {
            await e.detail;
            if (e.detail.state === "verified") {
                const challengeData = new FormData(document.forms["altcha-submission"]);
                try {
                   const response = await fetch("/dam/submit/", {
                        method: "POST",
                        body: challengeData,
                    });
                    const result = await response.json();
                    if ("success" in result) {
                        window.location.replace("/ark:/67531/metapth1065501/m1/");
                    } else {
                        document.getElementById('altcha-content').innerHTML = `${result.error} If you are unable to reach our site content, please <a href="https://texashistory.unt.edu/feedback/?cat=Technical+Issue&user_feedback=Altcha+Challenge+Issue+Details%3A">let us know</a>.`;
                    }
                } catch (error) {
                    document.getElementById('altcha-content').innerHTML = `${error} If you are unable to reach our site content, please <a href="https://texashistory.unt.edu/feedback/?cat=Technical+Issue&user_feedback=Altcha+Challenge+Issue+Details%3A">let us know</a>.`;
                    console.error("Challenge submission error:", error);
                }
            }
        });
    </script>
</body>
</html>
